{
  "name": "examnova-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "A Windows-first study workbench for Chinese university students.",
  "author": "ExamNova",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "electron .",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "katex": "^0.16.38",
    "next": "15.4.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "24.3.0",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.4.0",
    "typescript": "5.9.2"
  },
  "build": {
    "appId": "com.examnova.desktop",
    "productName": "ExamNova",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend-dist",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ],
      "artifactName": "ExamNova-Setup-${version}.${ext}"
    }
  }
}
